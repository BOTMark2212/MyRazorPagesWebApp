@page
@model MyRazorPagesWebApp.Pages.Orders.IndexModel
@{
}

<div>
    <h2>Orders (@Model.Orders.Count)</h2>
    <a asp-page="./Create">Create New Order</a>
    <table border="1" cellpadding="5" cellspacing="0">
        <thead>
            <tr>
                <th>OrderId</th>
                <th>Customer</th>
                <th>Employee</th>
                <th>OrderDate</th>
                <th>ShipCity</th>
                <th>Freight</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in Model.Orders)
            {
                <tr>
                    <td>@o.OrderId</td>
                    <td>@(o.Customer?.CustomerId ?? "No info")</td>
                    <td>@(o.Employee?.FirstName + " " + o.Employee?.LastName ?? "No info")</td>
                    <td>@o.OrderDate?.ToString("yyyy-MM-dd")</td>
                    <td>@o.ShipCity</td>
                    <td>@o.Freight</td>
                    <td>
                        <a asp-page="./Detail" asp-route-orderid="@o.OrderId">Detail</a>
                        <a asp-page="./Edit" asp-route-orderid="@o.OrderId">Edit</a>
                        <a asp-page="./Delete" asp-route-orderid="@o.OrderId">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
