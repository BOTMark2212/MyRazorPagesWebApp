@page "{orderid}"
@model MyRazorPagesWebApp.Pages.Orders.DeleteModel
@{
}

@if (Model.Message != String.Empty)
{
    <div>
        @Model.Message
    </div>
}

@if (Model.Order != null)
{
    <div>
        <h2>Delete Order</h2>
        <p>Are you sure you want to delete this order?</p>
        <div>
            <p>OrderId: @Model.Order.OrderId</p>
            <p>Customer: @Model.Order.CustomerId</p>
            <p>OrderDate: @Model.Order.OrderDate?.ToString("yyyy-MM-dd")</p>
            <p>ShipCity: @Model.Order.ShipCity</p>
        </div>
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="OrderId" value="@Model.Order.OrderId" />
            <button type="submit">Delete</button>
            <a asp-page="./Index">Cancel</a>
        </form>
    </div>
}
else
{
    <div>Order not found</div>
}
