@page "{employeeid}"
@model MyRazorPagesWebApp.Pages.Employees.DeleteModel
@{
}

@if (Model.Message != String.Empty)
{
    <div>
        @Model.Message
    </div>
}

@if (Model.Employee != null)
{
    <div>
        <h2>Delete Employee</h2>
        <p>Are you sure you want to delete this employee?</p>
        <div>
            <p>EmployeeId: @Model.Employee.EmployeeId</p>
            <p>FirstName: @Model.Employee.FirstName</p>
            <p>LastName: @Model.Employee.LastName</p>
            <p>Title: @Model.Employee.Title</p>
            <p>HireDate: @Model.Employee.HireDate?.ToString("yyyy-MM-dd")</p>
        </div>
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="EmployeeId" value="@Model.Employee.EmployeeId" />
            <button type="submit">Delete</button>
            <a asp-page="./Index">Cancel</a>
        </form>
    </div>
}
else
{
    <div>Employee not found</div>
}
